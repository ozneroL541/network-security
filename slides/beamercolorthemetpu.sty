\mode<presentation>

% light font on dark background and vice versa

\DeclareOptionBeamer{dark}{
	\def \TPUmaincolor {tpuwhite}
	\def \TPUsubcolor {tpugreen}
}
\DeclareOptionBeamer{light}{
	\def \TPUmaincolor {tpublack}
	\def \TPUsubcolor {tpudarkgreen}
}

\ExecuteOptionsBeamer{light}
\ProcessOptionsBeamer

% defining recommended TPU colours

\definecolor{tpuwhite}{RGB}{255,255,255}
\definecolor{tpublack}{RGB}{0,0,0}
\definecolor{tpugreen}{RGB}{128,191,68}
\definecolor{tpudarkgreen}{RGB}{32,151,64}

\definecolor{extragreen}{RGB}{0,166,81}
\definecolor{extrared}{RGB}{240,78,35}
\definecolor{extrablue}{RGB}{0,114,188}
\definecolor{extraorange}{RGB}{247,148,30}

\definecolor{slidenumber}{RGB}{59,56,56}		% slide number colour matches the logo

\setbeamercolor*{structure}{fg = \TPUmaincolor}
\setbeamercolor*{alerted text}{fg = \TPUsubcolor}
\setbeamercolor*{normal text}{fg = \TPUmaincolor}
\setbeamertemplate{itemize items}{\color{\TPUsubcolor}\tiny$\blacksquare$}	% square itemize bullets

\setbeamercolor*{date in head/foot}{fg = tpugreen}

\mode
<all>
