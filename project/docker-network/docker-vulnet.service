[Unit]
Description=Docker Vulnet Service
After=network.target docker.service
StartLimitIntervalSec=0

[Service]
Type=simple
Restart=on-failure
RestartSec=1
User=root
WorkingDirectory=/root/network-security/project/docker-network
ExecStart=/root/network-security/project/docker-network/setup.sh

[Install]
WantedBy=multi-user.target
