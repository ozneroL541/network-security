\mode<presentation>

% This is the main .sty file

\RequirePackage{graphicx}
\RequirePackage{tikz}	% most of the layout is done using tikz
\RequirePackage[skins]{tcolorbox}
\RequirePackage{setspace}

% options for light/dark theme and the English logo

\DeclareOptionBeamer{dark}{
	\def \TPUtheme {dk}
}
\DeclareOptionBeamer{light}{
	\def \TPUtheme {lt}
}

\DeclareOptionBeamer{enlogo}{
	\def \TPUlogo {en}
}

\ExecuteOptionsBeamer{light, enlogo}
\ProcessOptionsBeamer

\useinnertheme[\TPUtheme,\TPUlogo]{tpu}
\useoutertheme{tpu}
\usecolortheme[\TPUtheme]{tpu}
\usefonttheme{tpu}

\mode
<all>
